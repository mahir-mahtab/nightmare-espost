// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id                   String         @id @default(uuid())
  slug                 String         @unique
  title                String
  season               String?
  game                 String
  mode                 String?
  password             String
  registrationCount    Int            @default(0) @map("registration_count")
  maxSlots             Int            @default(0) @map("max_slots")
  streamStartTime      String?        @map("stream_start_time")
  auctionWindowSeconds Int            @default(30) @map("auction_window_seconds")
  bannerUrl            String?        @map("banner_url")
  sponsorImageUrl      String?        @map("sponsor_image_url")
  playerBasePrice      Int            @default(1000) @map("player_base_price")
  ownerCoins           Int            @default(10000) @map("owner_coins")
  status               EventStatus    @default(UPCOMING)
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  teams                Team[]
  players              Player[]
  owners               Owner[]
  auctionLots          AuctionLot[]
  actionLogs           ActionLog[]

  @@index([slug])
  @@index([status])
  @@map("events")
}

enum EventStatus {
  UPCOMING
  LIVE
  COMPLETED
}

enum PlayerRole {
  IGL
  Support
  Assaulter
  Sniper
}

model Team {
  id         String   @id @default(uuid())
  eventId    String   @map("event_id")
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name       String
  ownerId    String   @map("owner_id")
  owner      Owner    @relation(fields: [ownerId], references: [id])
  coinsLeft  Int      @default(0) @map("coins_left")
  createdAt  DateTime @default(now()) @map("created_at")

  players    Player[]

  @@index([eventId])
  @@map("teams")
}

model Owner {
  id         String   @id @default(uuid())
  eventId    String   @map("event_id")
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name       String
  email      String
  passwordHash String? @map("password_hash")
  avatarUrl  String?  @map("avatar_url")
  createdAt  DateTime @default(now()) @map("created_at")

  teams          Team[]

  @@index([eventId])
  @@unique([eventId, email])
  @@map("owners")
}

model Player {
  id           String        @id @default(uuid())
  eventId      String        @map("event_id")
  event        Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name         String
  email        String
  role         PlayerRole
  rankPoint    Int           @default(0) @map("rank_point")
  basePrice    Int           @default(0) @map("base_price")
  imageUrl     String?       @map("image_url")
  status       PlayerStatus  @default(ACTIVE)
  soldToTeamId String?       @map("sold_to_team_id")
  soldToTeam   Team?         @relation(fields: [soldToTeamId], references: [id])
  finalPrice   Int?          @map("final_price")
  createdAt    DateTime      @default(now()) @map("created_at")

  auctionLots  AuctionLot[]

  @@index([eventId])
  @@index([status])
  @@unique([eventId, email])
  @@map("players")
}

enum PlayerStatus {
  ACTIVE
  SOLD
  UNSOLD
}

model AuctionLot {
  id         String         @id @default(uuid())
  eventId    String         @map("event_id")
  event      Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  playerId   String         @map("player_id")
  player     Player         @relation(fields: [playerId], references: [id])
  status     AuctionStatus  @default(PENDING)
  endsAt     DateTime?      @map("ends_at")
  lotOrder   Int            @map("lot_order")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  @@index([eventId])
  @@index([status])
  @@index([lotOrder])
  @@map("auction_lots")
}

enum AuctionStatus {
  PENDING
  ACTIVE
  SOLD
  UNSOLD
}

model ActionLog {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  action    String
  data      Json
  timestamp DateTime @default(now())

  @@index([eventId])
  @@index([timestamp])
  @@map("action_logs")
}
